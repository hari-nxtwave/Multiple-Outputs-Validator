# Copy to .env (or just export in your shell) and fill in your key.
# LLM access goes through an OpenRouter proxy gateway that speaks the OpenAI
# Chat Completions API.

# Your gateway API key.
MO_API_KEY=YOUR_GATEWAY_API_KEY

# The proxy gateway base URL (OpenAI-compatible endpoint).
MO_BASE_URL=https://open-router-gateway.replit.app/api/proxy

# Model id in OpenRouter "<provider>/<model>" form.
MO_MODEL=anthropic/claude-haiku-4.5

# Optional overrides
# MO_MAX_TOKENS=16000
# MO_MAX_ITERATIONS=3
